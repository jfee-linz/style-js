{
  "name": "@linzjs/style",
  "version": "6.0.0",
  "license": "MIT",
  "repository": "github:linz/style-js",
  "bin": {
    "linz-style-install": "linz-style-install.mjs"
  },
  "files": [
    "build",
    "!build/**/__test__",
    "config",
    "linz-style-install.mjs",
    "oxfmt.config.ts",
    "oxlint.config.ts",
    "oxlint.config-react.ts",
    "tsconfig.base.json"
  ],
  "type": "module",
  "exports": {
    "./oxfmt.config": {
      "types": "./build/oxfmt.config.d.ts",
      "default": "./oxfmt.config.ts"
    },
    "./oxlint.config": {
      "types": "./build/oxlint.config.d.ts",
      "default": "./oxlint.config.ts"
    },
    "./oxlint.config-react": {
      "types": "./build/oxlint.config-react.d.ts",
      "default": "./oxlint.config-react.ts"
    },
    "./tsconfig.base.json": "./tsconfig.base.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "lint": "oxlint . && oxfmt --check .",
    "format": "oxlint --fix . && oxfmt ."
  },
  "dependencies": {
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^5.5.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^18.3.0"
  }
}
